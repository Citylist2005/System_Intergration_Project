{
  "name": "hr-payroll-workspace",
  "private": true,
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "start:all": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "start:backend": "cd backend && npm run start:dev",
    "build:backend": "cd backend && npm run build",
    "start:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build"
  }
}
